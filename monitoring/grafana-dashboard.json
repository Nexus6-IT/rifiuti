{
  "dashboard": {
    "title": "WasteFlow Permissions & RBAC Monitoring",
    "description": "T230: Phase 10 - Grafana dashboard for permission system performance",
    "tags": ["permissions", "rbac", "abac", "security"],
    "timezone": "browser",
    "refresh": "30s",
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "panels": [
      {
        "id": 1,
        "title": "Permission Check P99 Latency",
        "type": "graph",
        "datasource": "Prometheus",
        "targets": [
          {
            "expr": "histogram_quantile(0.99, rate(permission_check_duration_seconds_bucket[5m]))",
            "legendFormat": "P99 Latency",
            "refId": "A"
          },
          {
            "expr": "histogram_quantile(0.95, rate(permission_check_duration_seconds_bucket[5m]))",
            "legendFormat": "P95 Latency",
            "refId": "B"
          },
          {
            "expr": "histogram_quantile(0.50, rate(permission_check_duration_seconds_bucket[5m]))",
            "legendFormat": "P50 Latency",
            "refId": "C"
          }
        ],
        "yaxes": [
          {
            "format": "s",
            "label": "Latency (seconds)",
            "min": 0
          }
        ],
        "thresholds": [
          {
            "value": 0.01,
            "colorMode": "critical",
            "op": "gt",
            "fill": true,
            "line": true
          }
        ],
        "gridPos": {
          "x": 0,
          "y": 0,
          "w": 12,
          "h": 8
        }
      },
      {
        "id": 2,
        "title": "Permission Cache Hit Rate",
        "type": "gauge",
        "datasource": "Prometheus",
        "targets": [
          {
            "expr": "permission_cache_hit_ratio * 100",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "value": 0, "color": "red" },
                { "value": 90, "color": "yellow" },
                { "value": 95, "color": "green" }
              ]
            }
          }
        },
        "gridPos": {
          "x": 12,
          "y": 0,
          "w": 6,
          "h": 8
        }
      },
      {
        "id": 3,
        "title": "Audit Log Write Rate",
        "type": "graph",
        "datasource": "Prometheus",
        "targets": [
          {
            "expr": "rate(audit_log_writes_total[5m])",
            "legendFormat": "{{decision}} - {{resource_type}}",
            "refId": "A"
          }
        ],
        "yaxes": [
          {
            "format": "ops",
            "label": "Writes/sec",
            "min": 0
          }
        ],
        "gridPos": {
          "x": 18,
          "y": 0,
          "w": 6,
          "h": 8
        }
      },
      {
        "id": 4,
        "title": "ABAC Policy Evaluation Latency",
        "type": "graph",
        "datasource": "Prometheus",
        "targets": [
          {
            "expr": "histogram_quantile(0.99, rate(abac_evaluation_duration_seconds_bucket[5m]))",
            "legendFormat": "P99 - {{resource_type}}",
            "refId": "A"
          }
        ],
        "yaxes": [
          {
            "format": "s",
            "label": "Latency (seconds)",
            "min": 0
          }
        ],
        "thresholds": [
          {
            "value": 0.005,
            "colorMode": "critical",
            "op": "gt",
            "fill": true,
            "line": true
          }
        ],
        "gridPos": {
          "x": 0,
          "y": 8,
          "w": 12,
          "h": 8
        }
      },
      {
        "id": 5,
        "title": "Permission Check Error Rate",
        "type": "graph",
        "datasource": "Prometheus",
        "targets": [
          {
            "expr": "rate(permission_check_duration_seconds_count{decision=\"DENY\"}[5m]) / rate(permission_check_duration_seconds_count[5m])",
            "legendFormat": "Denial Rate",
            "refId": "A"
          }
        ],
        "yaxes": [
          {
            "format": "percentunit",
            "label": "Denial Rate",
            "min": 0,
            "max": 1
          }
        ],
        "gridPos": {
          "x": 12,
          "y": 8,
          "w": 6,
          "h": 8
        }
      },
      {
        "id": 6,
        "title": "Active Temporary Grants",
        "type": "stat",
        "datasource": "Prometheus",
        "targets": [
          {
            "expr": "active_temporary_grants",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short"
          }
        },
        "gridPos": {
          "x": 18,
          "y": 8,
          "w": 6,
          "h": 8
        }
      },
      {
        "id": 7,
        "title": "Permission Checks by Resource",
        "type": "piechart",
        "datasource": "Prometheus",
        "targets": [
          {
            "expr": "sum by (resource) (rate(permission_check_duration_seconds_count[5m]))",
            "legendFormat": "{{resource}}",
            "refId": "A"
          }
        ],
        "gridPos": {
          "x": 0,
          "y": 16,
          "w": 12,
          "h": 8
        }
      },
      {
        "id": 8,
        "title": "ABAC Evaluations by Decision",
        "type": "graph",
        "datasource": "Prometheus",
        "targets": [
          {
            "expr": "rate(abac_evaluations_total[5m])",
            "legendFormat": "{{decision}} - {{resource_type}}",
            "refId": "A"
          }
        ],
        "yaxes": [
          {
            "format": "ops",
            "label": "Evaluations/sec",
            "min": 0
          }
        ],
        "gridPos": {
          "x": 12,
          "y": 16,
          "w": 12,
          "h": 8
        }
      }
    ]
  }
}
