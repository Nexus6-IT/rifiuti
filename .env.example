# WasteFlow - Development Environment Configuration
# Copy this file to .env and adjust values as needed

# ==========================================
# APPLICATION
# ==========================================
NODE_ENV=development
APP_VERSION=1.0.0-dev
PORT=3000
PUBLIC_URL=http://localhost:4200

# ==========================================
# DATABASE (PostgreSQL)
# ==========================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=wasteflow_dev
DB_USER=wasteflow
DB_PASSWORD=wasteflow123
DATABASE_URL=postgresql://wasteflow:wasteflow123@localhost:5432/wasteflow_dev

# ==========================================
# REDIS CACHE
# ==========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ==========================================
# JWT AUTHENTICATION
# ==========================================
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=dev-secret-change-in-production-12345678901234567890123456789012
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=dev-refresh-secret-change-in-production-12345678901234567890
JWT_REFRESH_EXPIRES_IN=7d

# ==========================================
# KEYCLOAK (SPID/CIE)
# ==========================================
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=wasteflow
KEYCLOAK_CLIENT_ID=wasteflow-backend
KEYCLOAK_CLIENT_SECRET=dev-client-secret

# Admin credentials (for Keycloak setup)
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# ==========================================
# RENTRI API (Mock in development)
# ==========================================
RENTRI_API_URL=https://api-test.rentri.gov.it
RENTRI_API_KEY=mock-api-key-for-development
RENTRI_TIMEOUT=30000
RENTRI_MOCK_MODE=true

# ==========================================
# EMAIL (MailHog for local development)
# ==========================================
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_SECURE=false
EMAIL_FROM=noreply@wasteflow.local

# ==========================================
# FILE STORAGE (Local in development)
# ==========================================
STORAGE_TYPE=local
STORAGE_PATH=./uploads

# AWS S3 (only for production)
# AWS_REGION=eu-south-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# S3_BUCKET=wasteflow-dev

# ==========================================
# MONITORING (Optional in development)
# ==========================================
# SENTRY_DSN=
# NEW_RELIC_LICENSE_KEY=

# ==========================================
# LOGGING
# ==========================================
LOG_LEVEL=debug
LOG_FORMAT=pretty

# ==========================================
# CORS (Allow all origins in development)
# ==========================================
CORS_ORIGIN=http://localhost:4200,http://localhost:3000
CORS_CREDENTIALS=true

# ==========================================
# RATE LIMITING (Permissive in development)
# ==========================================
RATE_LIMIT_ENABLED=false
RATE_LIMIT_MAX=1000
RATE_LIMIT_WINDOW=60000

# ==========================================
# DATABASE BACKUP
# ==========================================
BACKUP_ENABLED=false
BACKUP_CRON=0 2 * * *
BACKUP_RETENTION_DAYS=30

# ==========================================
# DEVELOPMENT TOOLS
# ==========================================
# Seed database on startup
DB_SEED_ON_START=false

# Enable API documentation
API_DOCS_ENABLED=true

# Enable hot reload
HOT_RELOAD=true
