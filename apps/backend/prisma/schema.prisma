// Prisma schema for WasteFlow
// Multi-tenant architecture with Row-Level Security (RLS)

generator client {
  provider        = "prisma-client-js"
  // NB: `multiSchema` rimosso — era abilitato ma non usato (nessun @@schema /
  // datasource.schemas). Con un singolo schema `public` faceva generare a
  // `prisma migrate dev` un drop/recreate totale invece di ALTER incrementali,
  // rompendo ogni migrazione successiva alla baseline.
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgcrypto]
}

// ============================================================================
// MULTI-TENANT CORE
// ============================================================================

/// Tenant represents an organization (company) using the system
/// Each tenant is isolated via Row-Level Security policies
model Tenant {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Company identification
  partitaIva     String  @unique @map("partita_iva") @db.VarChar(11)
  ragioneSociale String  @map("ragione_sociale") @db.VarChar(255)
  pec            String? @db.VarChar(255)

  // Address
  address    String @db.VarChar(255)
  city       String @db.VarChar(100)
  province   String @db.VarChar(2)
  postalCode String @map("postal_code") @db.VarChar(5)
  country    String @default("IT") @db.VarChar(2)

  // Subscription management
  subscriptionTier   SubscriptionTier   @default(TRIAL) @map("subscription_tier")
  subscriptionStatus SubscriptionStatus @default(TRIAL) @map("subscription_status")
  subscriptionStart  DateTime           @default(now()) @map("subscription_start")
  subscriptionEnd    DateTime?          @map("subscription_end")

  // Usage limits
  firLimitPerMonth Int @default(100) @map("fir_limit_per_month")
  userLimitTotal   Int @default(5) @map("user_limit_total")

  // Relationships
  users            User[]
  firs             FIR[]
  mudReports       MUDReport[]
  companyTemplates CompanyTemplate[]
  notifications    Notification[]
  produttori       Produttore[]
  trasportatori    Trasportatore[]
  destinatari      Destinatario[]

  @@map("tenants")
}

enum SubscriptionTier {
  TRIAL
  PROFESSIONAL
  ENTERPRISE

  @@map("subscription_tier")
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  EXPIRED
  SUSPENDED

  @@map("subscription_status")
}

// ============================================================================
// USER MANAGEMENT
// ============================================================================

model User {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  keycloakId String @unique @map("keycloak_id") @db.VarChar(255)

  fiscalCode String  @map("fiscal_code") @db.VarChar(16)
  firstName  String  @map("first_name") @db.VarChar(100)
  lastName   String  @map("last_name") @db.VarChar(100)
  email      String  @db.VarChar(255)
  phone      String? @db.VarChar(20)

  role UserRole @default(OPERATOR)

  notificationPreferences Json? @map("notification_preferences")

  signatureCertificate     String?   @map("signature_certificate") @db.Text
  signatureCertificateHash String?   @map("signature_certificate_hash") @db.VarChar(64)
  signatureValidUntil      DateTime? @map("signature_valid_until")

  tenant                  Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  producedFIRs            FIR[]            @relation("ProducerUser")
  carrierFIRs             FIR[]            @relation("CarrierUser")
  receiverFIRs            FIR[]            @relation("ReceiverUser")
  firSignatures           FIRSignature[]
  notifications           Notification[]
  activityLogs            ActivityLog[]
  createdBackupSchedules  BackupSchedule[] @relation("CreatedByUser")
  executedBackupHistories BackupHistory[]  @relation("ExecutedByUser")

  @@unique([tenantId, fiscalCode])
  @@index([tenantId])
  @@index([keycloakId])
  @@map("users")
}

enum UserRole {
  ADMIN
  OPERATOR
  VIEWER

  @@map("user_role")
}

// ============================================================================
// FIR (Formulario Identificazione Rifiuti) - Core Domain
// ============================================================================

model FIR {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  firNumber String @map("fir_number") @db.VarChar(50)

  status             FIRStatus @default(DRAFT)
  workflowVersion    Int       @default(1) @map("workflow_version")
  submittedAt        DateTime? @map("submitted_at")
  completedAt        DateTime? @map("completed_at")
  cancelledAt        DateTime? @map("cancelled_at")
  cancellationReason String?   @map("cancellation_reason") @db.Text

  // producerUserId = utente (operatore) che ha creato il FIR (FK obbligatoria a
  // User). producerId = riferimento al registro Produttore da cui è stato preso
  // lo "snapshot" anagrafico immutabile (campi *Name/*PartitaIva/*Address). Il
  // FIR è un documento legale: conserva lo snapshot, non un join live.
  producerUserId     String  @map("producer_user_id") @db.Uuid
  producerId         String? @map("producer_id") @db.Uuid
  producerPartitaIva String  @map("producer_partita_iva") @db.VarChar(11)
  producerName       String  @map("producer_name") @db.VarChar(255)
  producerAddress    String  @map("producer_address") @db.VarChar(500)
  producerContact    String? @map("producer_contact") @db.VarChar(255)

  carrierUserId       String? @map("carrier_user_id") @db.Uuid
  carrierId           String? @map("carrier_id") @db.Uuid
  carrierPartitaIva   String  @map("carrier_partita_iva") @db.VarChar(11)
  carrierName         String  @map("carrier_name") @db.VarChar(255)
  carrierVehiclePlate String  @map("carrier_vehicle_plate") @db.VarChar(20)
  carrierContact      String? @map("carrier_contact") @db.VarChar(255)

  receiverUserId     String? @map("receiver_user_id") @db.Uuid
  receiverId         String? @map("receiver_id") @db.Uuid
  receiverPartitaIva String  @map("receiver_partita_iva") @db.VarChar(11)
  receiverName       String  @map("receiver_name") @db.VarChar(255)
  receiverAddress    String  @map("receiver_address") @db.VarChar(500)
  receiverContact    String? @map("receiver_contact") @db.VarChar(255)

  cerCode          String  @map("cer_code") @db.VarChar(6)
  wasteDescription String  @map("waste_description") @db.VarChar(500)
  wasteCategory    String  @map("waste_category") @db.VarChar(100)
  quantity         Decimal @db.Decimal(10, 2)
  unit             String  @default("KG") @db.VarChar(10)

  // Tipo di operazione sul rifiuto presso il destinatario: recupero (R) o
  // smaltimento (D). Necessario per l'aggregazione MUD (recyclingRate) e per
  // il rendering del FIR. Default DISPOSAL (conservativo) finche' il dominio
  // non cattura il valore in fase di creazione FIR.
  wasteOperationType WasteOperationType @default(DISPOSAL) @map("waste_operation_type")

  transportDate        DateTime  @map("transport_date")
  estimatedArrivalDate DateTime? @map("estimated_arrival_date")
  actualArrivalDate    DateTime? @map("actual_arrival_date")
  transportNotes       String?   @map("transport_notes") @db.Text

  rentriSyncStatus     RENTRISyncStatus @default(PENDING) @map("rentri_sync_status")
  rentriProtocolNumber String?          @map("rentri_protocol_number") @db.VarChar(100)
  rentriSyncedAt       DateTime?        @map("rentri_synced_at")
  rentriSyncAttempts   Int              @default(0) @map("rentri_sync_attempts")
  rentriLastSyncError  String?          @map("rentri_last_sync_error") @db.Text
  rentriNextRetryAt    DateTime?        @map("rentri_next_retry_at")

  attachmentUrls Json? @map("attachment_urls")

  tenant       Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  producerUser User           @relation("ProducerUser", fields: [producerUserId], references: [id])
  carrierUser  User?          @relation("CarrierUser", fields: [carrierUserId], references: [id])
  receiverUser User?          @relation("ReceiverUser", fields: [receiverUserId], references: [id])
  signatures   FIRSignature[]
  activityLogs ActivityLog[]

  @@unique([tenantId, firNumber])
  @@index([tenantId])
  @@index([status])
  @@index([rentriSyncStatus])
  @@index([transportDate])
  @@index([cerCode])
  @@index([tenantId, wasteOperationType])
  @@map("firs")
}

enum FIRStatus {
  DRAFT
  AWAITING_PRODUCER
  AWAITING_CARRIER
  AWAITING_RECEIVER
  COMPLETED
  SYNCED_TO_RENTRI
  CANCELLED

  @@map("fir_status")
}

enum RENTRISyncStatus {
  PENDING
  SYNCING
  SYNCED
  FAILED
  PERMANENTLY_FAILED

  @@map("rentri_sync_status")
}

/// Tipo di operazione di destinazione del rifiuto (D.Lgs 152/2006):
/// RECOVERY = operazioni R (recupero), DISPOSAL = operazioni D (smaltimento).
enum WasteOperationType {
  RECOVERY
  DISPOSAL

  @@map("waste_operation_type")
}

model FIRSignature {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  firId     String   @map("fir_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  role            String   @db.VarChar(50)
  signedAt        DateTime @map("signed_at")
  signatureMethod String   @default("ECDSA-SHA256") @map("signature_method") @db.VarChar(50)

  signatureValue  String @map("signature_value") @db.Text
  certificateHash String @map("certificate_hash") @db.VarChar(64)
  documentHash    String @map("document_hash") @db.VarChar(64)

  timestampToken String? @map("timestamp_token") @db.Text

  fir  FIR  @relation(fields: [firId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  @@index([firId])
  @@index([userId])
  @@map("fir_signatures")
}

model MUDReport {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  year        Int       @db.Integer
  status      MUDStatus @default(DRAFT)
  submittedAt DateTime? @map("submitted_at")
  submittedBy String?   @map("submitted_by") @db.Uuid

  reportData Json @map("report_data")

  pdfUrl String? @map("pdf_url") @db.VarChar(500)
  xmlUrl String? @map("xml_url") @db.VarChar(500)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, year])
  @@index([tenantId])
  @@map("mud_reports")
}

enum MUDStatus {
  DRAFT
  REVIEWING
  SUBMITTED
  ARCHIVED

  @@map("mud_status")
}

model CompanyTemplate {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  name       String  @db.VarChar(100)
  logoUrl    String? @map("logo_url") @db.VarChar(500)
  logoBase64 String? @map("logo_base64") @db.Text

  headerText String? @map("header_text") @db.VarChar(500)
  footerText String? @map("footer_text") @db.VarChar(500)

  primaryColor   String @default("#3b82f6") @map("primary_color") @db.VarChar(7)
  secondaryColor String @default("#1e40af") @map("secondary_color") @db.VarChar(7)
  fontFamily     String @default("Roboto") @map("font_family") @db.VarChar(50)

  isDefault Boolean @default(false) @map("is_default")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, isDefault])
  @@map("company_templates")
}

model Notification {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  type     NotificationType
  title    String               @db.VarChar(255)
  message  String               @db.Text
  severity NotificationSeverity @default(INFO)

  relatedEntityId   String? @map("related_entity_id") @db.Uuid
  relatedEntityType String? @map("related_entity_type") @db.VarChar(50)
  actionUrl         String? @map("action_url") @db.VarChar(500)

  isRead    Boolean   @default(false) @map("is_read")
  readAt    DateTime? @map("read_at")
  expiresAt DateTime  @default(dbgenerated("now() + interval '30 days'")) @map("expires_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, userId])
  @@index([isRead])
  @@map("notifications")
}

enum NotificationType {
  FIR_DEADLINE_APPROACHING
  RENTRI_SYNC_FAILED
  RENTRI_SYNC_SUCCESS
  MUD_DEADLINE_APPROACHING
  SUBSCRIPTION_EXPIRING
  SIGNATURE_REQUIRED
  SYSTEM_ERROR

  @@map("notification_type")
}

enum NotificationSeverity {
  INFO
  WARNING
  ERROR

  @@map("notification_severity")
}

model ActivityLog {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  firId     String?  @map("fir_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  action      String @db.VarChar(100)
  description String @db.Text
  metadata    Json?

  correlationId String? @map("correlation_id") @db.VarChar(100)
  ipAddress     String? @map("ip_address") @db.VarChar(45)
  userAgent     String? @map("user_agent") @db.VarChar(500)

  user User? @relation(fields: [userId], references: [id])
  fir  FIR?  @relation(fields: [firId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId])
  @@index([firId])
  @@index([createdAt])
  @@index([correlationId])
  @@map("activity_logs")
}

model BackupSchedule {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  name          String          @db.VarChar(100)
  description   String?         @db.Text
  frequency     BackupFrequency
  retentionDays Int             @default(30) @map("retention_days")
  isActive      Boolean         @default(true) @map("is_active")

  nextRunAt     DateTime      @map("next_run_at")
  lastRunAt     DateTime?     @map("last_run_at")
  lastRunStatus BackupStatus? @map("last_run_status")

  createdBy String @map("created_by") @db.Uuid
  creator   User   @relation("CreatedByUser", fields: [createdBy], references: [id])

  backupHistories BackupHistory[]

  @@map("backup_schedules")
}

enum BackupFrequency {
  HOURLY
  DAILY
  WEEKLY
  MONTHLY

  @@map("backup_frequency")
}

model BackupHistory {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  scheduleId String   @map("schedule_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at")

  status      BackupStatus
  startedAt   DateTime     @map("started_at")
  completedAt DateTime?    @map("completed_at")
  durationMs  Int?         @map("duration_ms")

  s3Bucket   String?  @map("s3_bucket") @db.VarChar(255)
  s3Key      String?  @map("s3_key") @db.VarChar(500)
  fileSizeMB Decimal? @map("file_size_mb") @db.Decimal(10, 2)

  errorMessage String? @map("error_message") @db.Text

  executedBy String? @map("executed_by") @db.Uuid
  executor   User?   @relation("ExecutedByUser", fields: [executedBy], references: [id])

  schedule BackupSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  @@index([scheduleId])
  @@index([status])
  @@index([createdAt])
  @@map("backup_histories")
}

enum BackupStatus {
  PENDING
  IN_PROGRESS
  SUCCESS
  FAILED

  @@map("backup_status")
}

// ============================================================================
// CER CODES (Catalogo Europeo dei Rifiuti)
// ============================================================================

model CERCode {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  code         String  @unique @db.VarChar(10)
  description  String  @db.Text
  isPericoloso Boolean @default(false) @map("is_pericoloso")
  category     String  @db.VarChar(255)
  subcategory  String  @db.VarChar(255)

  @@index([code])
  @@index([category])
  @@map("cer_codes")
}

// ============================================================================
// REGISTRY (Anagrafiche: Produttori, Trasportatori, Destinatari)
// ============================================================================

model Produttore {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  ragioneSociale String @map("ragione_sociale") @db.VarChar(255)
  partitaIVA     String @map("partita_iva") @db.VarChar(11)

  // Sede Legale
  via       String @db.VarChar(255)
  civico    String @db.VarChar(20)
  cap       String @db.VarChar(5)
  comune    String @db.VarChar(100)
  provincia String @db.VarChar(2)

  // Contacts
  email    String? @db.VarChar(255)
  telefono String? @db.VarChar(20)
  pec      String? @db.VarChar(255)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, partitaIVA])
  @@index([tenantId])
  @@map("produttori")
}

model Trasportatore {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  ragioneSociale   String @map("ragione_sociale") @db.VarChar(255)
  partitaIVA       String @map("partita_iva") @db.VarChar(11)
  numeroIscrizione String @map("numero_iscrizione") @db.VarChar(50)

  // Sede Legale
  via       String @db.VarChar(255)
  civico    String @db.VarChar(20)
  cap       String @db.VarChar(5)
  comune    String @db.VarChar(100)
  provincia String @db.VarChar(2)

  // Contacts
  email    String? @db.VarChar(255)
  telefono String? @db.VarChar(20)
  pec      String? @db.VarChar(255)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, partitaIVA])
  @@index([tenantId])
  @@map("trasportatori")
}

model Destinatario {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  ragioneSociale       String @map("ragione_sociale") @db.VarChar(255)
  partitaIVA           String @map("partita_iva") @db.VarChar(11)
  numeroAutorizzazione String @map("numero_autorizzazione") @db.VarChar(50)

  // Sede
  via       String @db.VarChar(255)
  civico    String @db.VarChar(20)
  cap       String @db.VarChar(5)
  comune    String @db.VarChar(100)
  provincia String @db.VarChar(2)

  // Contacts
  email    String? @db.VarChar(255)
  telefono String? @db.VarChar(20)
  pec      String? @db.VarChar(255)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, partitaIVA])
  @@index([tenantId])
  @@map("destinatari")
}

// ============================================================================
// PERMISSIONS & ROLES SYSTEM
// ============================================================================

/// Role represents a named collection of permissions within a tenant
model Role {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  name         String  @db.VarChar(100)
  description  String? @db.Text
  isSystemRole Boolean @default(false) @map("is_system_role")
  createdBy    String  @map("created_by") @db.Uuid

  // Relationships
  permissions            RolePermission[]
  userRoles              UserRoleAssignment[]
  consultantAssociations ConsultantTenantAssociation[]
  changeHistory          RoleChangeHistory[]
  permissionRequests     PermissionRequest[]

  @@unique([tenantId, name])
  @@index([tenantId, isSystemRole])
  @@index([tenantId])
  @@map("roles")
}

/// Permission represents an atomic action on a resource
model Permission {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  resource    String  @db.VarChar(50) // "fir", "facility", "report"
  action      String  @db.VarChar(50) // "create", "read", "update", "delete"
  scope       String  @db.VarChar(50) // "own", "facility", "all"
  description String  @db.Text
  isSensitive Boolean @default(false) @map("is_sensitive")
  module      String  @db.VarChar(50) // "FIR", "Facility", "User", "Report", etc.

  // Relationships
  roles    RolePermission[]
  policies PermissionPolicy[]

  @@unique([resource, action, scope])
  @@index([module])
  @@index([resource])
  @@map("permissions")
}

/// UserRoleAssignment links users to roles with optional facility scoping
model UserRoleAssignment {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  roleId    String   @map("role_id") @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  assignedBy String    @map("assigned_by") @db.Uuid
  assignedAt DateTime  @default(now()) @map("assigned_at")
  expiresAt  DateTime? @map("expires_at")

  facilityIds      Json?   @map("facility_ids") // Array of facility IDs for scope="facility"
  isDelegated      Boolean @default(false) @map("is_delegated")
  delegationReason String? @map("delegation_reason") @db.Text

  // Relationships
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId, tenantId])
  @@index([userId, tenantId, expiresAt])
  @@index([tenantId])
  @@index([roleId])
  @@map("user_role_assignments")
}

/// PermissionPolicy defines ABAC rules for fine-grained access control
model PermissionPolicy {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  permissionId String   @map("permission_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  policyName       String  @db.VarChar(100)
  policyDefinition Json    @map("policy_definition") // ABAC rules (conditions, attributes)
  evaluationOrder  Int     @default(0) @map("evaluation_order")
  isActive         Boolean @default(true) @map("is_active")
  version          Int     @default(1)

  // Relationships
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@index([permissionId])
  @@index([isActive, evaluationOrder])
  @@map("permission_policies")
}

/// PermissionAuditLog records every permission check for compliance (10-year retention)
model PermissionAuditLog {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  spidFiscalCode    String   @map("spid_fiscal_code") @db.VarChar(16)
  actionAttempted   String   @map("action_attempted") @db.VarChar(255)
  resourceType      String   @map("resource_type") @db.VarChar(50)
  resourceId        String?  @map("resource_id") @db.Uuid
  decision          String   @db.VarChar(20) // "ALLOW", "DENY"
  evaluatedPolicies Json?    @map("evaluated_policies")
  contextAttributes Json?    @map("context_attributes")
  timestamp         DateTime @default(now())
  sessionId         String   @map("session_id") @db.VarChar(100)

  // Cryptographic chaining for tamper detection
  previousEntryHash String? @map("previous_entry_hash") @db.VarChar(64)
  currentHash       String  @map("current_hash") @db.VarChar(64)

  @@index([tenantId, userId])
  @@index([timestamp])
  @@index([resourceType, resourceId])
  @@index([decision])
  @@map("permission_audit_logs")
}

/// RoleChangeHistory tracks all role modifications for audit trail
model RoleChangeHistory {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  roleId    String?  @map("role_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  entityType String   @db.VarChar(50) // "Role", "UserRole", "Permission"
  entityId   String   @map("entity_id") @db.Uuid
  changeType String   @map("change_type") @db.VarChar(50) // "CREATED", "UPDATED", "DELETED", "ASSIGNED", "REVOKED"
  changedBy  String   @map("changed_by") @db.Uuid
  oldValue   Json?    @map("old_value")
  newValue   Json?    @map("new_value")
  reason     String?  @db.Text
  timestamp  DateTime @default(now())

  // Relationships
  role Role? @relation(fields: [roleId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([roleId])
  @@index([entityType, entityId])
  @@index([timestamp])
  @@map("role_change_history")
}

/// ResourceOwnership tracks which users own specific resources
/// ResourceOwnership tracks assignments of resources to users
/// T184: Extended for User Story 6 - Task Assignment Automation
/// Supports vehicle, facility, zone, and route assignments with metadata
model ResourceOwnership {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  // Core fields
  userId       String @map("user_id") @db.Uuid // User who owns/is assigned the resource
  tenantId     String @map("tenant_id") @db.Uuid
  resourceType String @db.VarChar(50) // "vehicle", "facility", "zone", "route"
  resourceId   String @map("resource_id") @db.Uuid

  // Assignment tracking
  assignedBy String   @map("assigned_by") @db.Uuid // User ID who made the assignment
  assignedAt DateTime @default(now()) @map("assigned_at")

  // Expiration and deactivation
  expiresAt        DateTime? @map("expires_at")
  isActive         Boolean   @default(true) @map("is_active")
  revokedBy        String?   @map("revoked_by") @db.Uuid
  revokedAt        DateTime? @map("revoked_at")
  revocationReason String?   @map("revocation_reason") @db.Text
  reason           String?   @db.Text // Assignment reason/notes

  // Metadata (JSON) - stores certifications, capacity, zone info
  // Example: { "certifications": ["ADR", "Hazmat"], "capacity": 1500, "zone": "North" }
  metadata Json?

  // Legacy field for backward compatibility
  facilityId String? @map("facility_id") @db.Uuid

  @@unique([userId, resourceType, resourceId, isActive], name: "unique_active_assignment")
  @@index([userId, tenantId])
  @@index([resourceId, tenantId])
  @@index([tenantId, resourceType, isActive])
  @@index([tenantId, isActive, expiresAt])
  @@map("resource_ownership")
}

/// TemporaryPermissionGrant allows time-limited permission elevation
model TemporaryPermissionGrant {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  permissions           Json // Array of permission strings ["fir:create:all", "report:export:all"]
  startTime             DateTime  @map("start_time")
  endTime               DateTime  @map("end_time")
  grantedBy             String    @map("granted_by") @db.Uuid
  businessJustification String    @map("business_justification") @db.Text
  autoRevoked           Boolean   @default(false) @map("auto_revoked")
  revokedAt             DateTime? @map("revoked_at")

  @@index([userId, tenantId])
  @@index([endTime])
  @@map("temporary_permission_grants")
}

/// ConsultantTenantAssociation links consultant users to multiple client tenants
model ConsultantTenantAssociation {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  consultantUserId String   @map("consultant_user_id") @db.Uuid
  tenantId         String   @map("tenant_id") @db.Uuid
  roleId           String   @map("role_id") @db.Uuid
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  addedBy   String    @map("added_by") @db.Uuid
  addedAt   DateTime  @default(now()) @map("added_at")
  expiresAt DateTime? @map("expires_at")
  isActive  Boolean   @default(true) @map("is_active")

  // Relationships
  role Role @relation(fields: [roleId], references: [id])

  @@unique([consultantUserId, tenantId])
  @@index([consultantUserId])
  @@index([tenantId])
  @@index([isActive])
  @@map("consultant_tenant_associations")
}

/// PermissionRequest allows users to request permission elevation
model PermissionRequest {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  tenantId        String   @map("tenant_id") @db.Uuid
  requestedRoleId String?  @map("requested_role_id") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  requestedPermissions  Json?     @map("requested_permissions") // Array of permission strings
  businessJustification String    @map("business_justification") @db.Text
  duration              Int? // Duration in hours
  status                String    @default("PENDING") @db.VarChar(20) // "PENDING", "APPROVED", "DENIED"
  reviewedBy            String?   @map("reviewed_by") @db.Uuid
  reviewedAt            DateTime? @map("reviewed_at")
  denialReason          String?   @map("denial_reason") @db.Text

  // Relationships
  requestedRole Role? @relation(fields: [requestedRoleId], references: [id])

  @@index([userId, tenantId])
  @@index([status])
  @@map("permission_requests")
}

/// RolePermission junction table linking roles to permissions
model RolePermission {
  roleId       String   @map("role_id") @db.Uuid
  permissionId String   @map("permission_id") @db.Uuid
  grantedAt    DateTime @default(now()) @map("granted_at")
  grantedBy    String   @map("granted_by") @db.Uuid

  // Relationships
  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
  @@map("role_permissions")
}

/// AbacPolicy represents Attribute-Based Access Control policies
/// T222: Phase 10 - ABAC Policy Engine
model AbacPolicy {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  name         String           @unique @db.VarChar(100)
  resourceType String           @map("resource_type") @db.VarChar(50) // "fir", "facility", "report"
  effect       AbacPolicyEffect @default(ALLOW)
  conditions   Json // JSON structure: { operator: "AND", rules: [...] }
  priority     Int              @default(100)
  isActive     Boolean          @default(true) @map("is_active")
  description  String?          @db.Text
  createdBy    String           @map("created_by") @db.Uuid

  @@index([resourceType, isActive, priority])
  @@index([isActive, priority])
  @@map("abac_policies")
}

enum AbacPolicyEffect {
  ALLOW
  DENY

  @@map("abac_policy_effect")
}

/// Contratto di gestione rifiuti tra produttore e controparte
/// (trasportatore/smaltitore/intermediario). Supporta più modelli di pricing e
/// un workflow di stato; abilita l'auto-compilazione dei FIR da contratto
/// attivo. Tenant-scoped. (MVP: billing/firma/AI/marketplace sono follow-up.)
model Contract {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  contractNumber String @map("contract_number") @db.VarChar(50)

  // Parti (riferimenti al registro anagrafiche)
  producerId       String           @map("producer_id") @db.Uuid
  counterpartyId   String           @map("counterparty_id") @db.Uuid
  counterpartyType CounterpartyType @map("counterparty_type")

  contractType ContractType @map("contract_type")
  description  String?      @db.Text
  cerCodes     String[]     @map("cer_codes") // CER coperti dal contratto

  // Pricing
  pricingModel  PricingModel @map("pricing_model")
  basePrice     Decimal?     @map("base_price") @db.Decimal(10, 2)
  unitOfMeasure String       @default("kg") @map("unit_of_measure") @db.VarChar(10)
  pricingConfig Json?        @map("pricing_config") // tier/zone/ecc.

  // Termini
  startDate         DateTime  @map("start_date")
  endDate           DateTime? @map("end_date")
  durationMonths    Int?      @map("duration_months")
  autoRenew         Boolean   @default(false) @map("auto_renew")
  renewalNoticeDays Int       @default(60) @map("renewal_notice_days")

  // Pagamento
  paymentTerms     String @default("net_30") @map("payment_terms") @db.VarChar(20)
  billingFrequency String @default("monthly") @map("billing_frequency") @db.VarChar(20)

  status ContractStatus @default(DRAFT)

  @@unique([tenantId, contractNumber])
  @@index([tenantId, status])
  @@index([tenantId, producerId])
  @@map("contracts")
}

enum CounterpartyType {
  TRANSPORTER
  DISPOSER
  BROKER

  @@map("counterparty_type")
}

enum ContractType {
  WASTE_DISPOSAL
  WASTE_TRANSPORT
  FULL_SERVICE
  FRAMEWORK

  @@map("contract_type")
}

enum PricingModel {
  FLAT_RATE
  PAY_PER_LIFT
  PAY_BY_WEIGHT
  PAY_BY_VOLUME
  ZONE_BASED
  TIERED_VOLUME
  MINIMUM_GUARANTEE
  HYBRID

  @@map("pricing_model")
}

enum ContractStatus {
  DRAFT
  PENDING_APPROVAL
  ACTIVE
  SUSPENDED
  EXPIRED
  TERMINATED

  @@map("contract_status")
}

/// Movimento del registro cronologico di carico/scarico rifiuti
/// (D.Lgs 152/2006). I CARICO incrementano la giacenza in deposito temporaneo,
/// gli SCARICO la decrementano (tipicamente collegati a un FIR). Base per il
/// calcolo giacenze e per il monitoraggio dei limiti di deposito temporaneo.
model WasteMovement {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  type         WasteMovementType
  cerCode      String   @map("cer_code") @db.VarChar(6)
  quantity     Decimal  @db.Decimal(10, 2)
  unit         String   @default("KG") @db.VarChar(10)
  movementDate DateTime @map("movement_date")
  /// SCARICO: FIR collegato (uscita verso trasportatore/destinatario).
  firId        String?  @map("fir_id") @db.Uuid
  notes        String?  @db.Text

  @@index([tenantId, cerCode])
  @@index([tenantId, movementDate])
  @@map("waste_movements")
}

enum WasteMovementType {
  CARICO
  SCARICO

  @@map("waste_movement_type")
}

/// Credenziale RENTRI per-tenant (Modello di Interoperabilità AgID).
/// Ogni operatore (tenant) ha il PROPRIO certificato di interoperabilità: le
/// chiamate API RENTRI vengono firmate per conto di quel tenant. La chiave
/// privata è cifrata a riposo (AES-256-GCM, vedi rentri-crypto.util.ts) — mai
/// in chiaro nel DB. Un solo set di credenziali per tenant.
model RentriCredential {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String   @unique @map("tenant_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  /// Identificativo operatore/client (iss/sub della client_assertion).
  clientId       String @map("client_id") @db.VarChar(255)
  /// Certificato X.509 in PEM (per x5c). Non sensibile come la chiave.
  certificatePem String @map("certificate_pem") @db.Text
  /// Chiave privata PEM CIFRATA (formato iv:tag:ciphertext base64).
  privateKeyEnc  String @map("private_key_enc") @db.Text
  /// Algoritmo di firma JOSE: RS256 (cert RSA) | ES256 (cert EC).
  algorithm    String @default("RS256") @db.VarChar(10)
  /// Ambiente RENTRI dichiarato per la credenziale: demo | live.
  environment  String @default("demo") @db.VarChar(10)

  @@map("rentri_credentials")
}
