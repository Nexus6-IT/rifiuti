# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/wasteflow_dev?schema=public"

# Redis (for sessions, tokens, and caching)
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_PASSWORD=""
REDIS_DB=0

# JWT Configuration
JWT_SECRET="dev-secret-change-in-production-256-bits-minimum"
JWT_ACCESS_TOKEN_EXPIRATION="15m"
JWT_REFRESH_TOKEN_EXPIRATION="7d"
JWT_ISSUER="wasteflow.it"
JWT_AUDIENCE="wasteflow-api"

# SPID Configuration (SAML 2.0 Authentication)
# For development: use mock values
# For production: replace with real SPID Identity Provider values
SPID_IDP_ENTRY_POINT="https://idp.spid.gov.it/samlsso"
SPID_ENTRY_POINT="https://idp.spid.gov.it/samlsso"
SPID_ENTITY_ID="https://wasteflow.it"
SPID_ISSUER="https://wasteflow.it"
SPID_CALLBACK_URL="http://localhost:3000/api/v1/auth/spid/callback"
# IdP Certificate (provided by SPID Identity Provider)
SPID_IDP_CERT="-----BEGIN CERTIFICATE-----\nMII...your-idp-cert-here...\n-----END CERTIFICATE-----"
SPID_PUBLIC_CERT="-----BEGIN CERTIFICATE-----\nMII...your-sp-cert-here...\n-----END CERTIFICATE-----"
# Service Provider Private Key (generated for your app)
SPID_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMII...your-private-key-here...\n-----END PRIVATE KEY-----"

# Application
NODE_ENV="development"
PORT="3000"
API_PREFIX="api/v1"

# =============================================================================
# RENTRI — Registro Elettronico Nazionale per la Tracciabilità dei Rifiuti
# API: servizio `vidimazione-formulari` v1.0 (ModI AgID)
# Doc demo: https://demoapi.rentri.gov.it/docs?api=vidimazione-formulari&v=v1.0
# Doc prod:  https://api.rentri.gov.it/docs
#
# STATO: "pronto-ma-non-collegato" — il codice è completo, il go-live richiede:
#   1. ATTIVARE: completare l'iscrizione su rentri.gov.it (area operatori)
#   2. ATTIVARE: caricare il certificato di interoperabilità via admin UI
#              (PUT /api/v1/rentri/credential) oppure tramite le env vars qui sotto
#   3. ATTIVARE: impostare RENTRI_MODE=live e RENTRI_API_URL=https://demoapi.rentri.gov.it
#              (demoapi per test, poi https://api.rentri.gov.it per produzione)
#   4. CONFERMARE: verificare i path OpenAPI sull'interfaccia Swagger ufficiale
#              (oggi in rentri-api.client.ts: /vidimazione-formulari/v1.0/formulari)
# =============================================================================

# Modalità: "mock" (default, usa tools/rentri-mock) | "live" (ambiente reale RENTRI)
RENTRI_MODE="mock"

# URL base dell'API RENTRI:
#   demo    → https://demoapi.rentri.gov.it   (test, non richiede iscrizione definitiva)
#   prod    → https://api.rentri.gov.it        (ATTIVARE: dopo iscrizione + certificato)
#   mock    → http://localhost:3001             (default in modalità mock)
RENTRI_API_URL="https://demoapi.rentri.gov.it"

# API key usata SOLO in modalità mock (valore arbitrario)
RENTRI_API_KEY="demo-key"

# --- Solo per RENTRI_MODE=live (Modello di Interoperabilità AgID) -----------
# Identificativo operatore/client (iss/sub della client_assertion JWT).
# Si ottiene nell'area operatori RENTRI dopo l'accreditamento.
# ATTIVARE: sostituire con il proprio client ID dopo l'iscrizione.
RENTRI_CLIENT_ID="your-operator-id"

# Endpoint OAuth2 per l'access token (default: <RENTRI_API_URL>/token).
# Lasciare vuoto per usare il default.
RENTRI_TOKEN_URL=""

# Audience attese nei JWT (default: token endpoint / base URL).
# Lasciare vuoti per usare i default derivati da RENTRI_API_URL.
RENTRI_TOKEN_AUDIENCE=""
RENTRI_SIGNATURE_AUDIENCE=""

# Certificato X.509 e chiave privata PEM (newline come \n letterali).
# Usati come fallback single-operator; in multi-tenant ogni tenant gestisce
# il proprio certificato via API admin (PUT /api/v1/rentri/credential).
# ATTIVARE: inserire il certificato qualificato RENTRI (area operatori).
RENTRI_CERTIFICATE_PEM=""
RENTRI_PRIVATE_KEY_PEM=""

# Algoritmo di firma JOSE: RS256 per cert RSA (default) | ES256 per cert EC.
RENTRI_JWT_ALG="RS256"

# Validità (secondi) dei JWT generati (client_assertion + firma di integrità).
RENTRI_JWT_TTL_SECONDS="300"

# Secret per cifrare a riposo le chiavi private RENTRI dei tenant (AES-256-GCM).
# OBBLIGATORIO in multi-tenant. Generare con: openssl rand -hex 32
# ATTIVARE: impostare un valore forte (idealmente da un KMS) prima del go-live.
RENTRI_CREDENTIAL_ENC_KEY=""

# AWS (for production)
AWS_REGION="eu-south-1"
AWS_S3_BUCKET="wasteflow-documents-dev"

# ============================================================================
# ERROR TRACKING — Bugsink (self-hosted, compatibile Sentry SDK)
# ============================================================================
# Lascia vuoto in sviluppo (l'SDK è un no-op). In produzione imposta il DSN
# del progetto Bugsink (http://bugsink:8000) configurato su /opt/bugsink/.
# Formato: http://<32hex>@bugsink:8000/<project_id>  (UUID senza trattini)
# ATTIVARE: copiare il DSN dal pannello Bugsink → Project → SDK Setup.
SENTRY_DSN=""

# ============================================================================
# ROLES & PERMISSIONS SYSTEM (Phase 10 - Added 2025-11-02)
# ============================================================================

# Permission Cache Configuration
PERMISSION_CACHE_TTL="3600"  # Time-to-live for permission cache in seconds (default: 1 hour)

# ABAC (Attribute-Based Access Control) Configuration
ABAC_EVALUATION_ENABLED="true"  # Enable ABAC policy evaluation (default: true)
MAX_ABAC_POLICIES_PER_RESOURCE="100"  # Maximum number of ABAC policies per resource type

# Security & Rate Limiting
RATE_LIMIT_ENABLED="true"  # Enable rate limiting middleware (default: true)
RATE_LIMIT_WINDOW_MS="60000"  # Rate limit window in milliseconds (default: 1 minute)
RATE_LIMIT_MAX_REQUESTS="100"  # Maximum requests per window per IP

# Monitoring & Metrics
PROMETHEUS_ENABLED="true"  # Enable Prometheus metrics endpoint (default: true)
GRAFANA_URL="https://grafana.wasteflow.it"  # Grafana dashboard URL for monitoring

# Performance Targets (Success Criteria from spec.md)
# Target: <10ms P99 authorization latency (SC-007)
# Target: >95% cache hit rate (SC-008)
# Target: >1000 RPS throughput (SC-007)

# ============================================================================
# BILLING SaaS — Stripe (WS-F: Pagamenti & abbonamento)
# ============================================================================
# STATO: "pronto-ma-non-collegato" — il codice è completo.
# Senza queste variabili il billing è in modalità no-op (app non crasha).
#
# Listino piani WasteFlow (v1.0 — giugno 2026):
#   TRIAL        €0 / 30 giorni — 10 FIR/mese, 2 utenti, funzionalità base
#   PROFESSIONAL €79 /mese      — 200 FIR/mese, 5 utenti, tutti i moduli operativi
#   ENTERPRISE   €199/mese      — FIR illimitati, utenti illimitati, tutte le feature
#
# Fonti competitive: SistemaRentri (€99-€599/anno), AgonWaste (€29.90/mese/utente).
# WasteFlow posizionato come SaaS multi-tenant premium con RENTRI + ESG + MUD.
#
# ATTIVARE:
#   1. Creare account Stripe su https://stripe.com
#   2. Configurare i prezzi nel Stripe Dashboard (modalità ricorrente/mensile)
#   3. Impostare le variabili qui sotto con i valori del dashboard Stripe
#   4. Configurare il webhook: endpoint https://<app>/api/v1/billing/webhook
#      Selezionare eventi: checkout.session.completed, customer.subscription.*,
#      invoice.payment_failed, invoice.payment_succeeded
#   5. Copiare il signing secret del webhook in STRIPE_WEBHOOK_SECRET
# ============================================================================

# Chiave segreta Stripe (inizia con sk_test_ in test mode, sk_live_ in produzione).
# ATTIVARE: sostituire con la chiave dal Stripe Dashboard.
STRIPE_SECRET_KEY=""

# Secret per la verifica della firma webhook (inizia con whsec_).
# ATTIVARE: copiare dal Stripe Dashboard → Webhooks → signing secret.
STRIPE_WEBHOOK_SECRET=""

# Price ID Stripe per il piano Professional (€79/mese).
# ATTIVARE: creare un prezzo ricorrente nel Stripe Dashboard e copiare l'ID (price_...).
STRIPE_PRICE_ID_PROFESSIONAL=""

# Price ID Stripe per il piano Enterprise (€199/mese).
STRIPE_PRICE_ID_ENTERPRISE=""

# URL base del frontend (per costruire success/cancel URL del checkout).
# ATTIVARE: impostare l'URL pubblico del frontend in produzione.
FRONTEND_URL="https://rifiuti.ignicraft.com"

# ====================================================================
# Dati di riferimento condivisi (ATECO / ISTAT) — popolamento via cron
# ====================================================================
# URL dei CSV ufficiali (se non impostati, il dataset viene saltato).
# Formato colonne atteso (separatore configurabile con *_SEP, default ';'):
#   ATECO:    code;description
#   NAZIONI:  code;name;iso3
#   PROVINCE: sigla;code;name;regione
#   COMUNI:   code;name;provinciaSigla;codiceCatastale;cap
# Fonti ufficiali: ISTAT (comuni/province/nazioni), ISTAT ATECO 2007 agg.2022.
REFDATA_ATECO_URL=""
REFDATA_NAZIONI_URL=""
REFDATA_PROVINCE_URL=""
REFDATA_COMUNI_URL=""
# Separatore CSV per dataset (default ';')
#REFDATA_COMUNI_URL_SEP=";"
# Esegui il seed all'avvio se le tabelle sono vuote (default true)
REFDATA_SEED_ON_BOOT="true"
